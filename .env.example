# ────────────────────────────────────────────────────────────
# AIビブリオスタジアム — 環境変数設定ファイル
# このファイルをコピーして .env を作成し、各キーを設定してください
# ────────────────────────────────────────────────────────────

# ── Anthropic API Key（必須）────────────────────────────────
# Claude AI による構成生成・Q&A・バトラー推薦に使用
# 取得: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── VOICEVOX（推奨 / 無料・高品質日本語TTS）────────────────
# https://voicevox.hiroshiba.jp/ からインストールして起動するだけで有効
# 起動中は自動検出されます（設定不要）。未起動時は ElevenLabs にフォールバック。
# VOICEVOX_URL=http://localhost:50021   # デフォルト値（変更不要）
VOICEVOX_SPEAKER=1                      # 話者ID（下記参照）
# VOICEVOX_SPEAKER_PHASE1=1             # Phase1 模擬Q&A 用（未設定時は VOICEVOX_SPEAKER）
# VOICEVOX_SPEAKER_PHASE2=3             # Phase2 ドリームマッチ 用
# VOICEVOX_SPEAKER_PHASE3=8             # Phase3 バトラー推薦 用

# 主な話者ID一覧（VOICEVOXアプリ内でも確認可能）:
#   0: 四国めたん（あまあま）  1: 四国めたん（ノーマル）
#   2: 四国めたん（セクシー）  3: 四国めたん（ツンツン）
#   4: ずんだもん（あまあま）  5: ずんだもん（ノーマル）
#   8: 春日部つむぎ（ノーマル）  9: 波音リツ（ノーマル）
#  10: 雨晴はう（ノーマル）   11: 玄野武宏（ノーマル）
#  12: 白上虎太郎（ふつう）   13: 冥鳴ひまり（ノーマル）

# ── ElevenLabs API Key（任意 / VOICEVOXのフォールバック）──
# VOICEVOX 未起動時のフォールバックとして使用
# 取得: https://elevenlabs.io/
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=9BWtsMINqrJLrRacOk9x
# ELEVENLABS_VOICE_ID_PHASE1=
# ELEVENLABS_VOICE_ID_PHASE2=
# ELEVENLABS_VOICE_ID_PHASE3=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Google Books API Key（任意）─────────────────────────────
# Phase 1 の書籍検索に使用。未設定でも動作しますが、レートリミットが低くなります。
# 取得: https://console.cloud.google.com/ → Books API を有効化
GOOGLE_BOOKS_API_KEY=

# ── サーバーポート（デフォルト: 3000）──────────────────────
PORT=3000
